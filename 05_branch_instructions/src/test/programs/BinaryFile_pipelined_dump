







############################################################
# ADS I - Branch & Jump Test Program
# Tests:
#   - BEQ (taken / not taken)
#   - BNE (taken / not taken)
#   - BLT
#   - BGE
#   - BLTU
#   - BGEU
#   - JAL
#   - JALR
#   - Forwarding to branch comparator
#   - Control hazard flushing
############################################################

############################################################
# Setup
############################################################

addi x1, x0, 4          # x1 = 4
addi x2, x0, 5          # x2 = 5
addi x3, x0, -1         # x3 = -1 (0xFFFFFFFF)
addi x4, x0, 1          # x4 = 1

############################################################
# CASE 1 : BEQ NOT TAKEN
############################################################

beq x1, x2, BEQ_FAIL

addi x5, x0, 10         # executed

BEQ_FAIL:

############################################################
# CASE 2 : BEQ TAKEN (tests forwarding)
############################################################

add x6, x1, x2          # x6 = 9
addi x7, x0, 9

beq x6, x7, BEQ_TAKEN

addi x8, x0, 111        # flushed
addi x8, x0, 112        # flushed

BEQ_TAKEN:

addi x8, x0, 20

############################################################
# CASE 3 : BNE NOT TAKEN
############################################################

bne x1, x1, BNE_FAIL

addi x9, x0, 30

BNE_FAIL:

############################################################
# CASE 4 : BNE TAKEN
############################################################

bne x1, x2, BNE_TAKEN

addi x10, x0, 113       # flushed
addi x10, x0, 114       # flushed

BNE_TAKEN:

addi x10, x0, 40

############################################################
# CASE 5 : BLT
############################################################

blt x1, x2, BLT_TARGET

addi x11, x0, 115       # flushed

BLT_TARGET:

addi x11, x0, 50

############################################################
# CASE 6 : BGE
############################################################

bge x2, x1, BGE_TARGET

addi x12, x0, 116       # flushed

BGE_TARGET:

addi x12, x0, 60

############################################################
# CASE 7 : BLTU (NOT TAKEN)
############################################################
# Unsigned:
# 0xFFFFFFFF > 1

bltu x3, x4, BLTU_TARGET

addi x13, x0, 70

BLTU_TARGET:

############################################################
# CASE 8 : BGEU (TAKEN)
############################################################

bgeu x3, x4, BGEU_TARGET

addi x14, x0, 117       # flushed

BGEU_TARGET:

addi x14, x0, 80

############################################################
# CASE 9 : JAL
############################################################

jal x15, JAL_TARGET

addi x16, x0, 118       # flushed
addi x16, x0, 119       # flushed

JAL_TARGET:

addi x16, x0, 90

############################################################
# CASE 10 : JALR
############################################################

addi x17,x0, 0
addi  x17, x17, 12

jalr x18, x17, 0

addi x19, x0, 120       # flushed
addi x19, x0, 121       # flushed

JALR_TARGET:

addi x19, x0, 100
addi x19, x0, 17
############################################################
# END
############################################################

nop
nop
nop